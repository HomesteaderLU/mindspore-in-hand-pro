package com.mindspore.custommodel;

import android.Manifest;
import android.app.Activity;
import android.content.Intent;
import android.content.pm.PackageManager;
import android.graphics.Bitmap;
import android.graphics.BitmapFactory;
import android.net.Uri;
import android.os.Bundle;
import android.provider.MediaStore;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.Button;
import android.widget.ImageView;
import android.widget.TextView;
import android.widget.Toast;

import androidx.annotation.NonNull;
import androidx.annotation.Nullable;
import androidx.cardview.widget.CardView;
import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;
import androidx.fragment.app.Fragment;

import java.io.File;
import java.io.InputStream;

import com.mindspore.common.base.mvp.BaseFragment;

public class StyleClassifierFragment extends BaseFragment {

    private static final int REQUEST_SELECT_IMAGE = 1001;
    private static final int PERMISSION_REQUEST_CODE = 1002;

    private ImageView ivPreview;
    private TextView tvPlaceholder;
    private Button btnSelectImage;
    private CardView cardResult;
    private TextView textResult;
    private TextView tvPredictedStyle;
    private TextView tvConfidence;
    private TextView tvExecutionTime;

    private StyleClassifierExecutor executor;
    private Bitmap selectedBitmap;

    @Nullable
    @Override
    public View onCreateView(@NonNull LayoutInflater inflater, @Nullable ViewGroup container,
                             @Nullable Bundle savedInstanceState) {
        View view = inflater.inflate(R.layout.fragment_style_classifier, container, false);
        
        // 初始化视图
        ivPreview = view.findViewById(R.id.iv_preview);
        tvPlaceholder = view.findViewById(R.id.tv_placeholder);
        btnSelectImage = view.findViewById(R.id.btn_select_image);
        cardResult = view.findViewById(R.id.card_result);
        textResult = view.findViewById(R.id.text_result);
        tvPredictedStyle = view.findViewById(R.id.tv_predicted_style);
        tvConfidence = view.findViewById(R.id.tv_confidence);
        tvExecutionTime = view.findViewById(R.id.tv_execution_time);
        
        // 设置点击事件
        btnSelectImage.setOnClickListener(v -> selectImage());
        ivPreview.setOnClickListener(v -> selectImage());
        
        return view;
    }

    @Override
    public void onViewCreated(@NonNull View view, @Nullable Bundle savedInstanceState) {
        super.onViewCreated(view, savedInstanceState);
        loadModel();
    }

    private void loadModel() {
        try {
            File cacheFile = new File(requireContext().getCacheDir(), "style_classifier.ms");
            if (cacheFile.exists()) {
                textResult.setText("Model loaded successfully");
            } else {
                textResult.setText("Model not found");
                Toast.makeText(getContext(), "Model not loaded", Toast.LENGTH_SHORT).show();
            }
        } catch (Exception e) {
            Toast.makeText(getContext(), "Model not loaded", Toast.LENGTH_SHORT).show();
        }
    }
}
